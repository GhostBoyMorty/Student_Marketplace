@{
    ViewBag.Title = "User Profile - Vendly";
    Layout = null;
    var seller = ViewBag.Seller;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700&family=DM+Sans:wght@400;500&family=Dancing+Script:wght@700&display=swap" rel="stylesheet" />
    <link href="~/css/profile.css" rel="stylesheet" />
</head>
<body>
   <div class="profile-layout">

        <!-- LEFT SIDEBAR -->
        <aside class="profile-sidebar">

            <div class="sidebar-glow"></div>

            <div class="profile-picture-wrapper">

                <div class="profile-picture-box">

                    <img src="@seller.AvatarUrl"
                        alt="Profile Picture" />

                    <button class="change-image-btn">
                        Change Photo
                    </button>

                </div>

                <h2>Josh Pakii</h2>

                <span class="student-role">
                    DUT Student
                </span>

            </div>

            <div class="profile-progress-card">

                <div class="progress-top">
                    <strong>Profile Completion</strong>
                    <span>82%</span>
                </div>

                <div class="progress-bar">
                    <div class="progress-fill"></div>
                </div>

                <p>
                    Complete your profile to build more trust
                    with campus buyers.
                </p>

            </div>

            <div class="quick-stats">

                <button class="store-action-btn primary">
                    Create Store
                </button>

                <button class="store-action-btn secondary">
                    View Store
                </button>   

            </div>

        </aside>

        <!-- MAIN CONTENT -->
        <main class="profile-main-content">

            <div class="profile-banner">

                <div>
                    <h1>
                        Vendly. Profile
                    </h1>

                    <p>
                        Customize your account, update your
                        information and manage your presence
                        on Vendly.
                    </p>
                </div>

                <button class="save-btn-top">
                    Save Changes
                </button>

            </div>

            <div class="settings-card-large">

                <div class="card-title-row">
                    <h2>Personal Information</h2>
                    <span class="live-badge">
                        LIVE PROFILE
                    </span>
                </div>

                <div class="settings-grid">

                    <div class="input-group">
                        <label>Full Name</label>
                        <input type="text"
                            value="@seller.BusinessName">
                    </div>

                    <div class="input-group">
                        <label>Username</label>
                        <input type="text"
                            value="@@ndumiso">
                    </div>

                    <div class="input-group">
                        <label>Student Number</label>
                        <input type="text"
                            value="22345678">
                    </div>

                    <div class="input-group">
                        <label>Campus</label>
                        <input type="text"
                            value="@seller.Campus">
                    </div>

                    <div class="input-group">
                        <label>Email Address</label>
                        <input type="email"
                            value="@seller.Email">
                    </div>

                    <div class="input-group">
                        <label>Phone Number</label>
                        <input type="text"
                            value="@seller.Phone">
                    </div>

                    <div class="input-group full-width">
                        <label>Bio</label>

                        <textarea>
                            Creative student entrepreneur passionate about technology, campus business and building student communities.
                        </textarea>
                    </div>

                </div>

            </div>

            <div class="bottom-cards-row">

                <div class="mini-card">

                    <h3>Account Created</h3>

                    <p>12 January 2025</p>

                </div>

                <div class="mini-card">

                    <h3>Campus Status</h3>

                    <p>Verified Student</p>

                </div>

                <div class="mini-card">

                    <h3>Profile Visibility</h3>

                    <p>Public</p>

                </div>

            </div>

        </main>

    </div> 
</body>
</html>