@{
    Layout = null;
    ViewData["Title"] = "Seller Settings";
    var settings = ViewBag.SettingsData;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

    <link href="~/css/LandingPage.css" rel="stylesheet" />
    <link href="~/css/Settings.css" rel="stylesheet" />
</head>

<body>

    <div class="settings-layout">

        <!-- SIDEBAR -->
        <aside class="settings-sidebar">

            <div class="settings-sidebar-top">

                <div class="settings-brand">
                    <div class="brand-logo">V</div>

                    <div>
                        <h2>Vendly</h2>
                        <span>Seller Settings</span>
                    </div>
                </div>

                <div class="settings-store-card">

                    <img src="@settings.AvatarUrl"
                         alt="@settings.BusinessName"
                         class="store-avatar" />

                    <div class="store-info">
                        <h3>@settings.BusinessName</h3>
                        <p>@settings.Campus</p>
                    </div>

                </div>

            </div>

            <nav class="settings-nav">

                <a class="settings-link"
                   href="@Url.Action("SellerDashboard", "Home")">

                    <span>📊</span>
                    Dashboard

                </a>

                <a class="settings-link"
                   href="@Url.Action("Profile", "Home", new { sellerId = "demo-seller" })">

                    <span>🏪</span>
                    Business Profile

                </a>

                <a class="settings-link active"
                   href="@Url.Action("Settings", "Home")">

                    <span>⚙️</span>
                    Settings

                </a>

            </nav>

            <div class="sidebar-footer">

                <a href="@Url.Action("Index", "Home")"
                   class="back-marketplace">

                    ← Back to Marketplace

                </a>

            </div>

        </aside>

        <!-- MAIN -->
        <main class="settings-main">

            <!-- TOP HEADER -->
            <div class="settings-header">

                <div>
                    <span class="settings-label">STORE SETTINGS</span>

                    <h1>Account & Store Settings</h1>

                    <p>
                        Manage your business profile, payouts,
                        delivery preferences and notifications.
                    </p>
                </div>

                <div class="settings-header-actions">

                    <a class="secondary-btn"
                       href="@Url.Action("Profile", "Home", new { sellerId = "demo-seller" })">

                        View Store

                    </a>

                    <a class="primary-btn"
                       href="@Url.Action("SellerDashboard", "Home")">

                        Dashboard

                    </a>

                </div>

            </div>

            @if (TempData["SettingsSaved"] != null)
            {
                <div class="settings-alert success">
                    @TempData["SettingsSaved"]
                </div>
            }

            <!-- SETTINGS FORM -->
            <form method="post"
                  asp-action="SaveSettings"
                  asp-controller="Home"
                  class="settings-form">

                <!-- BUSINESS -->
                <section class="settings-card">

                    <div class="card-header">

                        <div>
                            <h2>Business Details</h2>
                            <p>
                                Information customers will see on your profile.
                            </p>
                        </div>

                    </div>

                    <div class="settings-grid">

                        <div class="input-group">
                            <label>Business Name</label>

                            <input type="text"
                                   name="BusinessName"
                                   value="@settings.BusinessName" />
                        </div>

                        <div class="input-group">
                            <label>Email Address</label>

                            <input type="email"
                                   name="Email"
                                   value="@settings.Email" />
                        </div>

                        <div class="input-group">
                            <label>Phone Number</label>

                            <input type="tel"
                                   name="Phone"
                                   value="@settings.Phone" />
                        </div>

                        <div class="input-group">
                            <label>Campus Location</label>

                            <input type="text"
                                   name="Campus"
                                   value="@settings.Campus" />
                        </div>

                        <div class="input-group">
                            <label>Delivery Radius</label>

                            <input type="text"
                                   name="DeliveryRadius"
                                   value="@settings.DeliveryRadius" />
                        </div>

                        <div class="input-group">
                            <label>Store Address</label>

                            <input type="text"
                                   name="Address"
                                   value="@settings.Address" />
                        </div>

                    </div>

                </section>

                <!-- PAYOUT -->
                <section class="settings-card">

                    <div class="card-header">

                        <div>
                            <h2>Payout & Payments</h2>
                            <p>
                                Update banking and payout information.
                            </p>
                        </div>

                    </div>

                    <div class="settings-grid">

                        <div class="input-group">
                            <label>Payout Method</label>

                            <input type="text"
                                   name="PayoutMethod"
                                   value="@settings.PayoutMethod" />
                        </div>

                        <div class="input-group">
                            <label>Bank Name</label>

                            <input type="text"
                                   name="BankName"
                                   value="@settings.BankName" />
                        </div>

                        <div class="input-group">
                            <label>Account Number</label>

                            <input type="text"
                                   name="AccountNumber"
                                   value="@settings.AccountNumber" />
                        </div>

                    </div>

                </section>

                <!-- NOTIFICATIONS -->
                <section class="settings-card">

                    <div class="card-header">

                        <div>
                            <h2>Notifications</h2>
                            <p>
                                Control how Vendly contacts you.
                            </p>
                        </div>

                    </div>

                    <div class="toggle-group">

                        <label class="toggle-card">

                            <div>
                                <h4>Email Notifications</h4>

                                <p>
                                    Receive order alerts and updates by email.
                                </p>
                            </div>

                            <input type="checkbox"
                                   name="NotificationEmail"
                                   @(settings.NotificationEmail ? "checked" : "") />

                        </label>

                        <label class="toggle-card">

                            <div>
                                <h4>SMS Notifications</h4>

                                <p>
                                    Get delivery and inquiry updates via SMS.
                                </p>
                            </div>

                            <input type="checkbox"
                                   name="NotificationSms"
                                   @(settings.NotificationSms ? "checked" : "") />

                        </label>

                    </div>

                </section>

                <!-- ACTIONS -->
                <div class="settings-actions">

                    <button type="submit" class="primary-btn save-btn">

                        Save Settings

                    </button>

                    <a class="secondary-btn"
                       href="@Url.Action("SellerDashboard", "Home")">

                        Cancel

                    </a>

                </div>

            </form>

        </main>

    </div>

</body>
</html>