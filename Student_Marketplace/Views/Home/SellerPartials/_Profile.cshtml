<link rel="stylesheet" href="~/css/DashboardPartials/profile.css" />


@{
    var profile = ViewBag.Profile;
}

<div class="page-header">

    <div>
        <h1>Profile</h1>
        <p>Manage your business information and account details</p>
    </div>

    <div class="header-actions">
        <button class="btn-primary">Save Changes</button>
    </div>

</div>

<!-- PROFILE HERO CARD -->
<div class="profile-hero">

    <div class="profile-avatar">
        <img src="@(profile?.AvatarUrl ?? "https://via.placeholder.com/150")" alt="Profile Image" />
    </div>

    <div class="profile-info">

        <h2>@(profile?.BusinessName ?? "Business Name")</h2>

        <p class="muted">@(profile?.Email ?? "email@example.com")</p>

        <span class="badge">
            Seller Account
        </span>

    </div>

</div>

<!-- PROFILE FORM GRID -->
<div class="profile-grid">

    <!-- LEFT COLUMN -->
    <div class="profile-card">

        <h3>Business Information</h3>

        <div class="form-group">
            <label>Business Name</label>
            <input type="text" value="@(profile?.BusinessName ?? "")" />
        </div>

        <div class="form-group">
            <label>Phone Number</label>
            <input type="text" value="@(profile?.Phone ?? "")" />
        </div>

        <div class="form-group">
            <label>Location</label>
            <input type="text" value="@(profile?.Address ?? "")" />
        </div>

        <div class="form-group">
            <label>Bio</label>
            <textarea>@(profile?.Bio ?? "")</textarea>
        </div>

    </div>

    <!-- RIGHT COLUMN -->
    <div class="profile-card">

        <h3>Account Settings</h3>

        <div class="form-group">
            <label>Email</label>
            <input type="email" value="@(profile?.Email ?? "")" />
        </div>

        <div class="form-group">
            <label>Password</label>
            <input type="password" value="********" />
        </div>

        <div class="form-group">
            <label>Notification Preferences</label>

            <div class="toggle-row">
                <span>Email Notifications</span>
                <input type="checkbox" checked />
            </div>

            <div class="toggle-row">
                <span>SMS Alerts</span>
                <input type="checkbox" />
            </div>

        </div>

    </div>

</div>

<!-- STATS SECTION -->
<div class="metrics-grid">

    <div class="metric-card">
        <h3>234</h3>
        <p>Total Sales</p>
    </div>

    <div class="metric-card">
        <h3>@(profile?.Rating ?? "0")</h3>
        <p>Rating</p>
    </div>

    <div class="metric-card">
        <h3>45</h3>
        <p>Orders</p>
    </div>

    <div class="metric-card">
        <h3>Jan 2024</h3>
        <p>Member Since</p>
    </div>

</div>