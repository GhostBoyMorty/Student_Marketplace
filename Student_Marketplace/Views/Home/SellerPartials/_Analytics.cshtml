<link rel="stylesheet" href="~/css/DashboardPartials/analytics.css" />

@{
    var data = ViewBag.Analytics;
}

<div class="analytics-page">

    <div class="page-header">
        <div>
            <h1>Analytics</h1>
            <p>Track your performance and sales insights</p>
        </div>
    </div>

    <!-- KEY METRICS WITH SVG ICONS -->
    <div class="analytics-metrics">

        <div class="analytics-card">
            <div class="analytics-card-header">
                <h3>Total Views</h3>
                <div class="analytics-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                </div>
            </div>
            <div class="analytics-value">@(data?.TotalViews ?? 0)</div>
            <div class="analytics-change positive">↑ 12% from last month</div>
        </div>

        <div class="analytics-card">
            <div class="analytics-card-header">
                <h3>Total Sales</h3>
                <div class="analytics-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="9" cy="21" r="1"></circle>
                        <circle cx="20" cy="21" r="1"></circle>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                    </svg>
                </div>
            </div>
            <div class="analytics-value">@(data?.TotalSales ?? 0)</div>
            <div class="analytics-change positive">↑ 8% from last month</div>
        </div>

        <div class="analytics-card">
            <div class="analytics-card-header">
                <h3>Conversion Rate</h3>
                <div class="analytics-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <polyline points="19 12 12 19 5 12"></polyline>
                    </svg>
                </div>
            </div>
            <div class="analytics-value">@(data?.ConversionRate ?? 0)%</div>
            <div class="analytics-change positive">↑ 2.1% improvement</div>
        </div>

        <div class="analytics-card">
            <div class="analytics-card-header">
                <h3>Revenue</h3>
                <div class="analytics-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="9"></circle>
                        <path d="M12 8v8M9.5 11h5M9.5 13h5"></path>
                    </svg>
                </div>
            </div>
            <div class="analytics-value">R@(data?.Revenue ?? 0)</div>
            <div class="analytics-change positive">↑ 15% growth</div>
        </div>

    </div>

    <!-- CHARTS & BREAKDOWN -->
    <div class="analytics-charts">

        <!-- SALES TREND CHART -->
        <div class="chart-card">
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 16px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 20px; height: 20px;">
                    <polyline points="23 6 13.5 15.5 8.5 10.5 1 17"></polyline>
                    <polyline points="17 6 23 6 23 12"></polyline>
                </svg>
                <h3 style="margin: 0;">Sales Trend (Last 7 Days)</h3>
            </div>
            <div class="simple-chart">
                <div class="bar-container">
                    <div class="bar" style="height: 40%;"></div>
                    <span class="bar-label">Mon</span>
                </div>
                <div class="bar-container">
                    <div class="bar" style="height: 65%;"></div>
                    <span class="bar-label">Tue</span>
                </div>
                <div class="bar-container">
                    <div class="bar" style="height: 75%;"></div>
                    <span class="bar-label">Wed</span>
                </div>
                <div class="bar-container">
                    <div class="bar" style="height: 55%;"></div>
                    <span class="bar-label">Thu</span>
                </div>
                <div class="bar-container">
                    <div class="bar" style="height: 85%;"></div>
                    <span class="bar-label">Fri</span>
                </div>
                <div class="bar-container">
                    <div class="bar" style="height: 95%;"></div>
                    <span class="bar-label">Sat</span>
                </div>
                <div class="bar-container">
                    <div class="bar" style="height: 70%;"></div>
                    <span class="bar-label">Sun</span>
                </div>
            </div>
        </div>

        <!-- TOP INSIGHTS -->
        <div class="chart-card">
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 16px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 20px; height: 20px;">
                    <polygon points="12 2 15.09 10.26 24 10.26 17.55 16.52 20.63 24.78 12 18.52 3.37 24.78 6.45 16.52 0 10.26 8.91 10.26"></polygon>
                </svg>
                <h3 style="margin: 0;">Quick Insights</h3>
            </div>
            <div class="analytics-insights">
                <div class="insight-card">
                    <div class="insight-card-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M6 9L12 15L18 9"></path>
                            <path d="M6 3L12 9L18 3"></path>
                        </svg>
                    </div>
                    <h4>Top Product</h4>
                    <p>@(data?.TopProduct ?? "Chicken Wrap Meal")</p>
                </div>

                <div class="insight-card">
                    <div class="insight-card-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                    </div>
                    <h4>Best Day</h4>
                    <p>@(data?.BestDay ?? "Friday")</p>
                </div>

                <div class="insight-card">
                    <div class="insight-card-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <polyline points="12 6 12 12 16 14"></polyline>
                        </svg>
                    </div>
                    <h4>Peak Hour</h4>
                    <p>@(data?.PeakHour ?? "12:00-14:00")</p>
                </div>

                <div class="insight-card">
                    <div class="insight-card-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                    <h4>Avg Order</h4>
                    <p>R@(data?.AverageOrderValue ?? 0)</p>
                </div>
            </div>
        </div>

    </div>

    <!-- PERFORMANCE BREAKDOWN -->
    <div class="analytics-breakdown">

        <!-- PRODUCT PERFORMANCE -->
        <div class="breakdown-card">
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 20px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 20px; height: 20px;">
                    <line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line>
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                    <line x1="12" y1="22.08" x2="12" y2="12"></line>
                </svg>
                <h3 style="margin: 0;">Product Performance</h3>
            </div>
            
            <div class="progress-item">
                <div class="progress-label">
                    <span>Chicken Wrap Meal</span>
                    <span>92%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 92%;"></div>
                </div>
            </div>

            <div class="progress-item">
                <div class="progress-label">
                    <span>Veggie Bowl Special</span>
                    <span>78%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 78%;"></div>
                </div>
            </div>

            <div class="progress-item">
                <div class="progress-label">
                    <span>Breakfast Sandwich</span>
                    <span>65%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 65%;"></div>
                </div>
            </div>

            <div class="progress-item">
                <div class="progress-label">
                    <span>Healthy Salad Box</span>
                    <span>45%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 45%;"></div>
                </div>
            </div>
        </div>

        <!-- VISITOR BREAKDOWN -->
        <div class="breakdown-card">
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 20px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 20px; height: 20px;">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
                <h3 style="margin: 0;">Visitor Analytics</h3>
            </div>

            <div class="progress-item">
                <div class="progress-label">
                    <span>New Visitors</span>
                    <span>62%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 62%;"></div>
                </div>
            </div>

            <div class="progress-item">
                <div class="progress-label">
                    <span>Returning Visitors</span>
                    <span>38%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 38%;"></div>
                </div>
            </div>

            <div class="progress-item">
                <div class="progress-label">
                    <span>Conversion Rate</span>
                    <span>7.2%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 7.2%;"></div>
                </div>
            </div>

            <div class="progress-item">
                <div class="progress-label">
                    <span>Mobile Users</span>
                    <span>71%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 71%;"></div>
                </div>
            </div>
        </div>

    </div>

</div>