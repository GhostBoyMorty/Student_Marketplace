<script>

    const modal =
        document.getElementById("listingModal");

    const openBtn =
        document.getElementById("openListingBtn");

    if(openBtn){

        openBtn.addEventListener("click", () => {

            modal.classList.add("active");

        });

    }

    function closeListingModal(){

        modal.classList.remove("active");

    }

</script>