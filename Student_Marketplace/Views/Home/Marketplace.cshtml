@{
    Layout = null;
}

<link rel="stylesheet" href="~/css/marketplace.css" />

<div class="marketplace-page">

    <!-- FLOATING HEADER -->
    <header class="market-header">

        <div class="header-top">

            <div class="brand">
                Vendly.
            </div>

            <div class="profile-wrapper">

                <div class="profile-box" id="profileBox">

                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M20 21C20 17.5 16.9 15 12 15C7.1 15 4 17.5 4 21"/>
                        <circle cx="12" cy="8" r="4"/>
                    </svg>

                </div>

                <div class="profile-dropdown" id="profileDropdown">

                    <a href="#">Profile</a>
                    <a href="#">Cart</a>
                    <a href="#">Orders</a>
                    <a href="#">Stores</a>
                    <a href="#">Chats</a>

                </div>

            </div>

        </div>

        <div class="hero-content">

            <h1>Find what students are selling.</h1>

            <p>
                Browse marketplace listings from students across your campus.
            </p>

            <div class="search-bar">

                <input type="text" placeholder="Search products..." />

                <button>
                    Search
                </button>

            </div>

        </div>

    </header>

    <!-- RESULTS -->
    <main class="results-section">

        <div class="listing-card">

            <div class="listing-image"></div>

            <div class="listing-info">

                <h3>MacBook Air M1</h3>

                <p class="price">R12 500</p>

                <p class="meta">
                    UJ Auckland Park
                </p>

            </div>

        </div>

        <div class="listing-card">

            <div class="listing-image"></div>

            <div class="listing-info">

                <h3>Accounting Textbooks</h3>

                <p class="price">R850</p>

                <p class="meta">
                    Wits Braamfontein
                </p>

            </div>

        </div>

    </main>

</div>

<script>

    const profileBox = document.getElementById("profileBox");
    const dropdown = document.getElementById("profileDropdown");

    profileBox.addEventListener("click", () => {

        dropdown.classList.toggle("active");

    });

    window.addEventListener("click", (e) => {

        if (
            !profileBox.contains(e.target) &&
            !dropdown.contains(e.target)
        ) {
            dropdown.classList.remove("active");
        }

    });

</script>