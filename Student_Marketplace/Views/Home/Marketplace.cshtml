    <script>
        // Marketplace functionality
        const marketplaceApp = (() => {
            // State management
            const state = {
                selectedCategory: 'products',
                selectedFilters: {
                    products: [],
                    services: [],
                    campus: 'all'
                },
                maxPrice: 1200,
                sortBy: 'newest',
                bookmarks: new Set()
            };

            // Initialize on page load
            function init() {
                attachEventListeners();
                loadBookmarks();
            }

            // Category pill toggle
            function attachEventListeners() {
                // Category pills
                document.querySelectorAll('.pill').forEach(pill => {
                    pill.addEventListener('click', (e) => handleCategoryChange(e.target));
                });

                // Product checkboxes
                document.querySelectorAll('.filter-section:nth-of-type(2) input[type="checkbox"]').forEach(checkbox => {
                    checkbox.addEventListener('change', () => updateFilters('products'));
                });

                // Service checkboxes
                document.querySelectorAll('.filter-section:nth-of-type(3) input[type="checkbox"]').forEach(checkbox => {
                    checkbox.addEventListener('change', () => updateFilters('services'));
                });

                // Price range
                const priceSlider = document.querySelector('.price-range input[type="range"]');
                if (priceSlider) {
                    priceSlider.addEventListener('input', (e) => handlePriceChange(e.target.value));
                }

                // Sort dropdown
                const sortSelect = document.querySelector('.filter-section:last-of-type select');
                if (sortSelect) {
                    sortSelect.addEventListener('change', (e) => handleSort(e.target.value));
                }

                // Campus filter
                document.getElementById('campusSelect')?.addEventListener('change', (e) => {
                    state.selectedFilters.campus = e.target.value;
                    filterListings();
                });

                // Search button
                document.querySelector('.search-bar button')?.addEventListener('click', () => handleSearch());

                // Search on Enter key
                document.querySelector('.search-bar input')?.addEventListener('keypress', (e) => {
                    if (e.key === 'Enter') handleSearch();
                });

                // Bookmark buttons
                document.querySelectorAll('.bookmark').forEach((btn, idx) => {
                    btn.addEventListener('click', (e) => toggleBookmark(e.target, idx));
                });

                // View all button
                document.querySelector('.section-heading button')?.addEventListener('click', () => {
                    alert('View all featured listings');
                });
            }

            function handleCategoryChange(pill) {
                // Remove active class from all pills
                document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
                // Add active class to clicked pill
                pill.classList.add('active');
                // Update state
                state.selectedCategory = pill.textContent.toLowerCase();
                filterListings();
            }

            function updateFilters(type) {
                const section = type === 'products' ? 2 : 3;
                const checkboxes = document.querySelectorAll(`.filter-section:nth-of-type(${section}) input[type="checkbox"]`);
                state.selectedFilters[type] = Array.from(checkboxes)
                    .filter(cb => cb.checked)
                    .map(cb => cb.parentElement.textContent.trim());
                filterListings();
            }

            function handlePriceChange(value) {
                state.maxPrice = parseInt(value);
                document.querySelector('.price-range .price-labels span:nth-of-type(2)').textContent = `R${value}`;
                filterListings();
            }

            function handleSort(sortValue) {
                state.sortBy = sortValue;
                sortListings();
            }

            function handleSearch() {
                const query = document.querySelector('.search-bar input').value.toLowerCase();
                if (query.trim() === '') {
                    filterListings();
                    return;
                }
                document.querySelectorAll('.listing-card').forEach(card => {
                    const title = card.querySelector('h3').textContent.toLowerCase();
                    const seller = card.querySelector('.listing-seller').textContent.toLowerCase();
                    const matches = title.includes(query) || seller.includes(query);
                    card.style.display = matches ? 'block' : 'none';
                });
            }

            function filterListings() {
                document.querySelectorAll('.listing-card').forEach(card => {
                    // Get card data
                    const title = card.querySelector('h3').textContent;
                    const price = parseInt(card.querySelector('.listing-price').textContent.replace('R', ''));
                    const type = ['Textbooks', 'Clothing', 'Phone', 'Food'].some(t => title.includes(t)) ? 'products' : 'services';

                    // Check category
                    if (state.selectedCategory !== type) {
                        card.style.display = 'none';
                        return;
                    }

                    // Check price
                    if (price > state.maxPrice) {
                        card.style.display = 'none';
                        return;
                    }

                    // Check filters
                    const hasFilter = state.selectedFilters[state.selectedCategory].length > 0;
                    if (hasFilter && !state.selectedFilters[state.selectedCategory].some(f => title.includes(f))) {
                        card.style.display = 'none';
                        return;
                    }

                    card.style.display = 'block';
                });
            }

            function sortListings() {
                const grid = document.querySelector('.listing-grid');
                const cards = Array.from(grid.querySelectorAll('.listing-card')).filter(c => c.style.display !== 'none');

                cards.sort((a, b) => {
                    const titleA = a.querySelector('h3').textContent;
                    const titleB = b.querySelector('h3').textContent;
                    const priceA = parseInt(a.querySelector('.listing-price').textContent.replace('R', ''));
                    const priceB = parseInt(b.querySelector('.listing-price').textContent.replace('R', ''));
                    const ratingA = parseFloat(a.querySelector('.listing-trust').textContent);
                    const ratingB = parseFloat(b.querySelector('.listing-trust').textContent);

                    switch (state.sortBy) {
                        case 'Price: Low to High':
                            return priceA - priceB;
                        case 'Price: High to Low':
                            return priceB - priceA;
                        case 'Highest Rated':
                            return ratingB - ratingA;
                        case 'Newest':
                        default:
                            return 0;
                    }
                });

                cards.forEach(card => grid.appendChild(card));
            }

            function toggleBookmark(btn, idx) {
                const key = `listing-${idx}`;
                if (state.bookmarks.has(key)) {
                    state.bookmarks.delete(key);
                    btn.textContent = '♥';
                    btn.style.opacity = '0.6';
                } else {
                    state.bookmarks.add(key);
                    btn.textContent = '♥';
                    btn.style.opacity = '1';
                    btn.style.color = '#e91e63';
                }
                saveBookmarks();
            }

            function saveBookmarks() {
                localStorage.setItem('vendly-bookmarks', JSON.stringify(Array.from(state.bookmarks)));
            }

            function loadBookmarks() {
                const saved = localStorage.getItem('vendly-bookmarks');
                if (saved) {
                    state.bookmarks = new Set(JSON.parse(saved));
                    document.querySelectorAll('.bookmark').forEach((btn, idx) => {
                        if (state.bookmarks.has(`listing-${idx}`)) {
                            btn.style.opacity = '1';
                            btn.style.color = '#e91e63';
                        }
                    });
                }
            }

            return { init };
        })();

        // Initialize when DOM is ready
        document.addEventListener('DOMContentLoaded', marketplaceApp.init);
    </script>
</body>
</html>
