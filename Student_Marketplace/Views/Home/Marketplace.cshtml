@{
    ViewBag.Title = "Vendly Marketplace";
    Layout = null;
    var userName = ViewBag.UserName ?? "Guest";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700&family=DM+Sans:wght@400;500&family=Dancing+Script:wght@700&display=swap" rel="stylesheet" />
    <link href="~/css/LandingPage.css" rel="stylesheet" />
    <link href="~/css/Marketplace.css" rel="stylesheet" />
</head>


<body>
    <div class="market-dashboard">
        <div class="page-navigation">
            <div class="nav-panel-header">
                <p class="nav-panel-copy">Quick access to core pages, seller tools, and upcoming features—so you can move through the marketplace faster.</p>
            </div>
            <div class="nav-section">
                <h4 class="nav-section-title">🏠 Core Pages</h4>
                <p class="nav-description">Navigate to the main user-facing pages for browsing, signing in, and marketplace access.</p>
                <div class="nav-buttons-grid">
                    <a class="nav-page-btn" href="@Url.Action("Index", "Home")">
                        <span class="nav-icon">🏠</span>
                        <span class="nav-label">Landing Page</span>
                    </a>
                    <a class="nav-page-btn" href="@Url.Action("Auth", "Home")">
                        <span class="nav-icon">🔐</span>
                        <span class="nav-label">Authentication</span>
                    </a>
                    <a class="nav-page-btn nav-current" href="@Url.Action("Marketplace", "Home")">
                        <span class="nav-icon">🛒</span>
                        <span class="nav-label">Marketplace</span>
                    </a>
                </div>
            </div>

            <div class="nav-section">
                <h4 class="nav-section-title">👨‍💼 Seller Pages</h4>
                <p class="nav-description">Manage your business profile and seller dashboard with quick links.</p>
                <div class="nav-buttons-grid">
                    <a class="nav-page-btn" href="@Url.Action("Profile", "Home", new { sellerId = "demo-seller" })">
                        <span class="nav-icon">🏪</span>
                        <span class="nav-label">Business Profile</span>
                    </a>
                    <a class="nav-page-btn" href="@Url.Action("SellerDashboard", "Home")">
                        <span class="nav-icon">📊</span>
                        <span class="nav-label">Seller Dashboard</span>
                    </a>
                </div>
            </div>

            <div class="nav-section">
                <h4 class="nav-section-title">🔮 Future Pages</h4>
                <p class="nav-description">These upcoming features are planned for the next release of the marketplace.</p>
                <div class="nav-buttons-grid">
                    <a class="nav-page-btn nav-future" href="#" onclick="alert('Messages page - Coming Soon!')">
                        <span class="nav-icon">💬</span>
                        <span class="nav-label">Messages</span>
                    </a>
                    <a class="nav-page-btn nav-future" href="#" onclick="alert('Orders page - Coming Soon!')">
                        <span class="nav-icon">📦</span>
                        <span class="nav-label">My Orders</span>
                    </a>
                    <a class="nav-page-btn nav-future" href="#" onclick="alert('Wishlist page - Coming Soon!')">
                        <span class="nav-icon">❤️</span>
                        <span class="nav-label">Wishlist</span>
                    </a>
                    <a class="nav-page-btn" href="@Url.Action("Settings", "Home")">
                        <span class="nav-icon">⚙️</span>
                        <span class="nav-label">Account Settings</span>
                    </a>
                    <a class="nav-page-btn nav-future" href="#" onclick="alert('Help page - Coming Soon!')">
                        <span class="nav-icon">❓</span>
                        <span class="nav-label">Help & Support</span>
                    </a>
                    <a class="nav-page-btn nav-future" href="#" onclick="alert('Admin page - Coming Soon!')">
                        <span class="nav-icon">👑</span>
                        <span class="nav-label">Admin Panel</span>
                    </a>
                </div>
            </div>
        </div>
        <header class="market-hero">
            <div class="hero-copy">
                <p class="hero-tag">DUT Student Marketplace</p>
                <h1>Welcome back, @userName</h1>
                <p class="hero-description">Find verified student sellers, services, and campus deals across Durban and Midlands campuses.</p>
                <p class="hero-note">Use the search bar to quickly find student sellers, products, and campus-specific deals.</p>
            </div>
            <div class="hero-actions">
                <div class="search-bar">
                    <input type="text" placeholder="Search keywords, business names, or product types" />
                    <button type="button">Search</button>
                </div>
                <div class="campus-toggle">
                    <label for="campusSelect">Campus filter</label>
                    <select id="campusSelect">
                        <option>All Campuses</option>
                        <option>Durban Campuses</option>
                        <option>Midlands Campus</option>
                    </select>
                </div>
            </div>
        </header>

        <main class="market-main">
            <aside class="market-sidebar">
                <div class="filter-card">
                    <div class="filter-card-header">
                        <h2>Refine search</h2>
                        <span>Sort and filter listings</span>
                    </div>
                    <div class="filter-section">
                        <p class="filter-title">Category</p>
                        <div class="pill-row">
                            <button type="button" class="pill active">Products</button>
                            <button type="button" class="pill">Services</button>
                        </div>
                    </div>
                    <div class="filter-section">
                        <p class="filter-title">Products</p>
                        <label><input type="checkbox" /> Clothing</label>
                        <label><input type="checkbox" /> Food</label>
                        <label><input type="checkbox" /> Textbooks</label>
                    </div>
                    <div class="filter-section">
                        <p class="filter-title">Services</p>
                        <label><input type="checkbox" /> Tutoring</label>
                        <label><input type="checkbox" /> Graphic Design</label>
                        <label><input type="checkbox" /> Hair Styling</label>
                    </div>
                    <div class="filter-section">
                        <p class="filter-title">Price range</p>
                        <div class="price-range">
                            <input type="range" min="0" max="1500" value="1200" />
                            <div class="price-labels">
                                <span>R0</span>
                                <span>R1500</span>
                            </div>
                        </div>
                    </div>
                    <div class="filter-section">
                        <p class="filter-title">Sort by</p>
                        <select>
                            <option>Newest</option>
                            <option>Price: Low to High</option>
                            <option>Price: High to Low</option>
                            <option>Highest Rated</option>
                        </select>
                    </div>
                </div>
            </aside>

